# Rename to .env and put your SerpAPI key here
SERPAPI_KEY=your_serpapi_api_key_here
# Optional: Google Custom Search credentials. If both Google and SerpAPI keys are present,
# the server will prefer Google when keys present.
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CX=your_google_cx_here

# Optional: force provider = "google" or "serpapi". If omitted, server prefers Google when keys are available.
PROVIDER=google
